<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.RECORD_AUDIO" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <!-- Required on Android 14+ (API 34) when declaring foregroundServiceType="dataSync" -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC" />

    <application
        android:name=".HermexApplication"
        android:allowBackup="false"
        android:label="@string/app_name"
        android:theme="@style/Theme.Hermex"
        android:usesCleartextTraffic="true">
        <!--
          MainActivity itself is not launcher-visible; the three activity-alias entries below own
          the MAIN/LAUNCHER intent-filter instead, so exactly one of them (never MainActivity
          directly) shows as the app's launcher icon. This is what lets the runtime app-icon
          switcher (see AppIconSwitcher) change which icon is visible via
          PackageManager.setComponentEnabledSetting() without needing to reinstall the app.
        -->
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:theme="@style/Theme.Hermex">
            <!-- hermex:// deep-link scheme (Android primary) -->
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="hermex" />
            </intent-filter>
            <!-- hermes-agent:// deep-link scheme (iOS parity) -->
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="hermes-agent" />
            </intent-filter>
            <!-- Share target: text (used for text-only shares) -->
            <intent-filter>
                <action android:name="android.intent.action.SEND" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:mimeType="text/plain" />
            </intent-filter>
            <!-- Share target: single file, image, PDF, or any type -->
            <intent-filter>
                <action android:name="android.intent.action.SEND" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:mimeType="*/*" />
            </intent-filter>
            <!-- Share target: multiple files, images, PDFs -->
            <intent-filter>
                <action android:name="android.intent.action.SEND_MULTIPLE" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:mimeType="*/*" />
            </intent-filter>
        </activity>

        <!--
          Foreground service that keeps the SSE stream alive while the user is backgrounded.
          foregroundServiceType="dataSync" is required on Android 14+ for services maintaining
          a live network data sync connection; pairing permission is declared above.
          Not exported: started only via explicit intent from within this package.
        -->
        <service
            android:name=".core.foreground.ChatStreamForegroundService"
            android:exported="false"
            android:foregroundServiceType="dataSync" />

        <receiver
            android:name=".widget.HermexWidgetProvider"
            android:exported="true">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/hermex_widget_provider" />
        </receiver>

        <!-- Light is the manifest-level default (enabled="true"); HermexApplication reconciles
             this against the stored AppIconVariant + current device dark mode on every app start,
             so a fresh install briefly shows Light before the very first reconciliation runs (or
             stays Light if that's what System/Light already resolves to). -->
        <activity-alias
            android:name=".LauncherLight"
            android:targetActivity=".MainActivity"
            android:icon="@mipmap/ic_launcher_light"
            android:roundIcon="@mipmap/ic_launcher_light_round"
            android:enabled="true"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity-alias>

        <activity-alias
            android:name=".LauncherDark"
            android:targetActivity=".MainActivity"
            android:icon="@mipmap/ic_launcher_dark"
            android:roundIcon="@mipmap/ic_launcher_dark_round"
            android:enabled="false"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity-alias>

        <activity-alias
            android:name=".LauncherDisco"
            android:targetActivity=".MainActivity"
            android:icon="@mipmap/ic_launcher_disco"
            android:roundIcon="@mipmap/ic_launcher_disco_round"
            android:enabled="false"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity-alias>
    </application>

</manifest>
